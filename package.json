{
  "name": "collet",
  "version": "1.0.1",
  "description": "Autonomous accounts receivable desktop bot",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "icons": "node scripts/generate-icons.js",
    "build:mac": "npm run icons && electron-builder --mac",
    "build:win": "npm run icons && electron-builder --win",
    "build:all": "npm run icons && electron-builder --mac --win",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3,keytar"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "better-sqlite3": "^9.4.3",
    "electron-log": "^5.1.2",
    "electron-updater": "^6.1.8",
    "googleapis": "^140.0.1",
    "keytar": "^7.9.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.9",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  }
}
