<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron's V8 JIT -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Required for Electron renderer unsigned memory -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Required to load dylibs not signed by Apple (native Node modules) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Network access for OAuth flows and accounting APIs -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Keychain access for storing OAuth tokens and license key -->
  <key>keychain-access-groups</key>
  <array>
    <string>$(AppIdentifierPrefix)com.collet.app</string>
  </array>
</dict>
</plist>
